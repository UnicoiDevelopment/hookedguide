{
  "expo": {
    "name": "HOOKED — Fish Smarter",
    "slug": "hooked-fish-smarter",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "hooked",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hookedguide.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HOOKED uses your location to detect your fishing spot, check local weather and water conditions, and provide state-specific fishing regulations.",
        "NSCameraUsageDescription": "HOOKED uses your camera to photograph your catches for your fishing log.",
        "NSPhotoLibraryUsageDescription": "HOOKED accesses your photo library to add catch photos to your fishing log.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "com.hookedguide.app"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      "expo-font",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
